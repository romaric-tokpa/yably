EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Carte in-app : MapLibre + raster MapTiler (recommandé) ou tuiles OSM par défaut.
# Clé gratuite : https://www.maptiler.com/cloud/ — limite mensuelle généreuse pour MVP.
EXPO_PUBLIC_MAPTILER_API_KEY=

# Géocodage inverse (optionnel) : si défini, utilisé en priorité sous le libellé « Position ».
# Sinon fallback expo-location / OS du téléphone.
EXPO_PUBLIC_LOCATIONIQ_API_KEY=

# Google Maps (optionnel, hors carte Yably — ex. liens « S’y rendre » vers l’app Google Maps).
GOOGLE_MAPS_IOS_API_KEY=
GOOGLE_MAPS_ANDROID_API_KEY=

# --- Développement local (après `npm run db:start`) ---
# URL API (toujours le port Kong) :
# EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#
# Clé client : avec le CLI récent, `supabase status` affiche « Publishable » (sb_publishable_…).
# C’est celle à mettre dans EXPO_PUBLIC_SUPABASE_ANON_KEY (équivalent anon local).
#
# Si `status` liste des « Stopped services » : attendre ~1 min puis réessayer ; vérifier avec
# `docker ps` (Kong/Auth/DB « healthy » suffit pour l’app REST + login).
#
# Connexion test téléphone (voir supabase/config.toml → [auth.sms.test_otp]) :
# numéro 07 00 00 00 01, code OTP 123456
