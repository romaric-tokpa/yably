{
  "name": "pharmacie-garde",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:localhost": "expo start --localhost",
    "start:clear": "expo start --clear",
    "start:tunnel": "expo start --tunnel",
    "android": "node scripts/expo-android-or-go.cjs",
    "android:emulator": "node scripts/check-android-env.cjs && expo start --android",
