    "test:watch": "jest --watch",
    "db:start": "supabase start --ignore-health-check",
    "db:start:strict": "supabase start",
    "db:restart": "supabase stop && supabase start --ignore-health-check",
    "db:stop": "supabase stop",
    "db:reset": "bash scripts/db-reset.sh"
  },
